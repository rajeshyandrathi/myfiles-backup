<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Dynamic Flow Progress Indicator</masterLabel>
    <description>This lwc renders a progress indicator based on the stages of a flow as inputs.</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="stages" label="Stages" type="String[]" role="inputOnly" />
            <property name="currentStage" label="Current Stage" type="String" role="inputOnly" />
            <property name="varient" label="Varient" type="String" role="inputOnly" default="base" />
            <property name="type" label="Type" type="String" role="inputOnly" default="base" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>