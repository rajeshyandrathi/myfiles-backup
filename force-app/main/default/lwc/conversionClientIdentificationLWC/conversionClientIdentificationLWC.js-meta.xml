<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>

    <targets>
        <target>lightning__FlowScreen</target>
    </targets>

    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">

            <property
                name="idType"
                type="String"
                label="Identification Type"
                role="OutputOnly"/>

            <property
                name="idNumber"
                type="String"
                label="Identification Number"
                role="OutputOnly"/>
            
            <property
                name="contentDocumentId"
                type="String"
                label="Content Document Id"
                role="OutputOnly"/>
            
            <property
                name="contentDocumentIds"
                type="String"
                label="Content Document IDs (Comma Separated)"
                description="A comma-separated list of IDs for all uploaded files."/>

            <property
                name="contentDocumentNames"
                type="String"
                label="Content Document Names (Comma Separated)"
                description="A comma-separated list of file names for all uploaded files."
                role="OutputOnly"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>